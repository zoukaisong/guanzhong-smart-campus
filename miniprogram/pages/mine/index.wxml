<view class="mine-page">
  <!-- 头像区 -->
  <view class="profile-header">
    <view class="avatar">👤</view>
    <text class="profile-name">{{user.name}}</text>
    <text class="profile-role">{{user.role_label}}</text>
    <text wx:if="{{user.class_name}}" class="profile-class">{{user.class_name}}</text>
  </view>

  <!-- 菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onTapEditProfile">
      <text class="menu-icon">✏️</text>
      <text class="menu-title">修改个人信息</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onTapAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-title">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="version">关中智慧校园 v1.0.0</view>
</view>
