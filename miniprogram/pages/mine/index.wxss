.mine-page { min-height: 100vh; background: #f5f5f5; }

/* ---- Header ---- */
.profile-header {
  background: linear-gradient(135deg, #1a6e3e 0%, #2e8b57 100%);
  padding: 80rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 20rpx;
}
.profile-name { font-size: 36rpx; font-weight: 600; margin-bottom: 8rpx; }
.profile-role { font-size: 26rpx; opacity: 0.85; margin-bottom: 4rpx; }
.profile-class { font-size: 24rpx; opacity: 0.7; }

/* ---- Menu ---- */
.menu-section {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}
.menu-item + .menu-item { border-top: 1rpx solid #f5f5f5; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-title { flex: 1; font-size: 30rpx; color: #333; }
.menu-arrow { font-size: 36rpx; color: #ccc; }

.version { text-align: center; font-size: 24rpx; color: #ccc; padding: 48rpx 0; }
