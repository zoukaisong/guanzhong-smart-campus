.tag-page { min-height: 100vh; background: #f5f5f5; }

/* ---- Step Common ---- */
.step-section { padding: 24rpx; }
.step-title { font-size: 34rpx; font-weight: 700; color: #333; margin-bottom: 24rpx; }
.step-header { display: flex; align-items: center; margin-bottom: 24rpx; }
.back-btn { font-size: 28rpx; color: #1a6e3e; margin-right: 16rpx; }

/* ---- Search ---- */
.search-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.search-input { flex: 1; height: 80rpx; background: #fff; border-radius: 12rpx; padding: 0 24rpx; font-size: 28rpx; }
.search-btn { background: #1a6e3e; color: #fff; border-radius: 12rpx; font-size: 28rpx; padding: 0 32rpx; height: 80rpx; line-height: 80rpx; border: none; }

/* ---- Tag Groups ---- */
.tag-group { margin-bottom: 32rpx; }
.group-title { font-size: 28rpx; font-weight: 600; color: #666; display: block; margin-bottom: 16rpx; }
.tag-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag-item {
  padding: 14rpx 28rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}
.tag-item.tag-item-selected {
  background: #1a6e3e !important;
  color: #fff !important;
  font-weight: 500;
}

/* ---- Description ---- */
.desc-section { margin: 32rpx 0; }
.desc-label { font-size: 28rpx; font-weight: 600; color: #666; display: block; margin-bottom: 12rpx; }
.desc-input {
  width: 100%;
  height: 160rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

/* ---- Photo Upload ---- */
.photo-upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.photo-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}
.photo-img {
  width: 100%;
  height: 100%;
}
.photo-delete {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}
.photo-add-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
}
.photo-add-icon { font-size: 48rpx; margin-bottom: 4rpx; }

/* ---- Buttons ---- */
.confirm-btn, .submit-btn {
  width: 100%;
  background: #1a6e3e;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
  margin-top: 32rpx;
}
.confirm-btn[disabled] {
  background: #ccc;
}

/* ---- Confirm ---- */
.confirm-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.confirm-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 8rpx; }
.confirm-value { font-size: 28rpx; color: #333; }
.confirm-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.confirm-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(26,110,62,0.1);
  color: #1a6e3e;
  border-radius: 8rpx;
  font-size: 26rpx;
}
