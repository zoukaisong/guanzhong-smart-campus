.detail-page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.loading-state { text-align: center; padding: 120rpx 0; color: #999; }

/* ---- Cards ---- */
.info-card {
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
}
.card-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.student-name { font-size: 40rpx; font-weight: 700; color: #1a6e3e; margin-bottom: 24rpx; }
.info-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-child { border-bottom: none; }
.info-label { width: 120rpx; font-size: 26rpx; color: #999; flex-shrink: 0; }
.info-value { flex: 1; font-size: 26rpx; color: #333; }

/* ---- Tags ---- */
.tags-section { margin-top: 8rpx; }
.tag-detail-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.tag-detail-item:last-child { border-bottom: none; }
.tag-name { font-size: 28rpx; font-weight: 500; color: #333; display: block; margin-bottom: 8rpx; }
.tag-categories { display: flex; flex-wrap: wrap; gap: 8rpx; }
.cat-tag {
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.cat-six { background: rgba(26,110,62,0.1); color: #1a6e3e; }
.cat-four { background: rgba(217,83,79,0.1); color: #d9534f; }
.cat-out { background: rgba(240,173,78,0.1); color: #c79121; }
.no-tags { font-size: 26rpx; color: #ccc; text-align: center; padding: 24rpx 0; }

/* ---- Out-of-school ---- */
.out-card { border-left: 6rpx solid #f0ad4e; }
.out-status-badge { margin-top: 8rpx; }
