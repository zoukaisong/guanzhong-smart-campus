.list-page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }

/* ---- Search ---- */
.search-bar { padding: 16rpx 24rpx; }
.search-input {
  width: 100%;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* ---- Tabs ---- */
.tabs {
  display: flex;
  background: #fff;
  margin: 0 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}
.tab-active {
  color: #1a6e3e;
  font-weight: 600;
}
.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 4rpx;
  background: #1a6e3e;
  border-radius: 2rpx;
}

/* ---- Sub Tabs ---- */
.sub-tabs {
  white-space: nowrap;
  padding: 16rpx 24rpx;
}
.sub-tab {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  background: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}
.sub-tab-active {
  background: rgba(26,110,62,0.1);
  color: #1a6e3e;
  font-weight: 500;
}

/* ---- Loading ---- */
.loading-tip {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #ccc;
}
