.import-page { min-height: 100vh; background: #f5f5f5; }
.import-card {
  margin: 48rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.import-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.import-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.import-desc { font-size: 26rpx; color: #999; margin-bottom: 48rpx; line-height: 1.5; }
.choose-btn {
  background: #1a6e3e;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border: none;
}
