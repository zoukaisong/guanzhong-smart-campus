.approvals-page { min-height: 100vh; background: #f5f5f5; padding: 24rpx 0; }
.page-title { font-size: 34rpx; font-weight: 700; color: #333; padding: 0 24rpx 16rpx; }

.approval-card {
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}
.card-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.user-name { font-size: 32rpx; font-weight: 600; color: #333; margin-right: 16rpx; }
.user-role { font-size: 24rpx; color: #1a6e3e; background: rgba(26,110,62,0.08); padding: 4rpx 12rpx; border-radius: 8rpx; }
.card-body { margin-bottom: 20rpx; }
.user-phone { display: block; font-size: 26rpx; color: #999; }
.user-time { display: block; font-size: 24rpx; color: #ccc; margin-top: 4rpx; }
.card-actions { display: flex; gap: 16rpx; justify-content: flex-end; }
.btn-approve, .btn-reject {
  padding: 12rpx 36rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  border: none;
}
.btn-approve { background: #1a6e3e; color: #fff; }
.btn-reject { background: #f5f5f5; color: #d9534f; }

.no-permission { padding-top: 120rpx; }
.loading-tip { text-align: center; padding: 32rpx; font-size: 24rpx; color: #ccc; }
