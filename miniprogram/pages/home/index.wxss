.home-page { min-height: 100vh; background: #f5f5f5; }

/* ---- Header ---- */
.home-header {
  background: linear-gradient(135deg, #1a6e3e 0%, #2e8b57 100%);
  padding: 60rpx 32rpx 40rpx;
  color: #fff;
}
.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.school-name { font-size: 40rpx; font-weight: 700; }
.user-info { font-size: 26rpx; opacity: 0.85; }
.header-class { margin-top: 12rpx; font-size: 28rpx; opacity: 0.8; }

/* ---- Stats ---- */
.stats-row {
  display: flex;
  margin: -30rpx 24rpx 24rpx;
  gap: 16rpx;
}
.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.stat-num { display: block; font-size: 48rpx; font-weight: 700; margin-bottom: 8rpx; }
.stat-six .stat-num { color: #1a6e3e; }
.stat-four .stat-num { color: #d9534f; }
.stat-out .stat-num { color: #f0ad4e; }
.stat-label { font-size: 22rpx; color: #999; }

/* ---- Entries ---- */
.section-title { font-size: 30rpx; font-weight: 600; color: #333; padding: 24rpx 24rpx 16rpx; }
.entry-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 16rpx;
}
.entry-item {
  width: calc(25% - 12rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.entry-icon { font-size: 48rpx; margin-bottom: 12rpx; }
.entry-title { font-size: 24rpx; color: #333; text-align: center; }
