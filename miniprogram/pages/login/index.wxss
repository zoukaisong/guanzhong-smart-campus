.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a6e3e 0%, #2e8b57 40%, #f5f5f5 40%);
  padding-top: 120rpx;
}
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}
.header-logo { font-size: 80rpx; margin-bottom: 20rpx; }
.header-title { font-size: 44rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.header-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.8); }

/* ---- Login ---- */
.login-section {
  margin: 60rpx 48rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  text-align: center;
}
.login-desc { font-size: 28rpx; color: #999; margin-bottom: 48rpx; }
.login-btn {
  background: #1a6e3e;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
}

/* ---- Register ---- */
.register-section {
  margin: 40rpx 48rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
}
.section-title { font-size: 34rpx; font-weight: 700; color: #333; margin-bottom: 36rpx; }
.form-group { margin-bottom: 32rpx; }
.form-label { display: block; font-size: 28rpx; color: #333; margin-bottom: 12rpx; font-weight: 500; }
.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.role-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.role-item {
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}
.role-item-active {
  background: rgba(26,110,62,0.08);
  color: #1a6e3e;
  border-color: #1a6e3e;
}
.submit-btn {
  background: #1a6e3e;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
  margin-top: 24rpx;
}
.form-tip { text-align: center; font-size: 24rpx; color: #999; margin-top: 20rpx; }

/* ---- Pending ---- */
.pending-section {
  margin: 60rpx 48rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 48rpx;
  text-align: center;
}
.pending-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.pending-title { font-size: 36rpx; font-weight: 700; color: #333; margin-bottom: 16rpx; }
.pending-desc { font-size: 28rpx; color: #999; margin-bottom: 48rpx; line-height: 1.6; }
.refresh-btn {
  background: transparent;
  color: #1a6e3e;
  border: 1rpx solid #1a6e3e;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
}
