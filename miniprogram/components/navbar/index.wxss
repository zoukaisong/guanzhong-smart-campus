.navbar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  color: #fff;
}
.navbar-back {
  width: 60rpx;
  display: flex;
  align-items: center;
}
.navbar-back-icon {
  font-size: 40rpx;
  color: #fff;
}
.navbar-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}
.navbar-placeholder {
  width: 60rpx;
}
