.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; opacity: 0.6; }
.empty-text { font-size: 28rpx; color: #999; margin-bottom: 32rpx; }
.empty-btn {
  border: 1rpx solid #1a6e3e;
  color: #1a6e3e;
  background: #fff;
  border-radius: 8rpx;
  padding: 12rpx 48rpx;
  font-size: 28rpx;
}
